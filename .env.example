# ─────────────────────────────────────────────────────────────
# AI FACTORY — Variables de entorno
# Copia este archivo como .env y rellena los valores
# NUNCA subas .env a Git (ya está en .gitignore)
# ─────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────
# Todos los modelos pasan por OpenRouter — un solo punto de facturación
OPENROUTER_API_KEY=sk-or-...

# ── Admin API ────────────────────────────────────────────────
# Genera con: openssl rand -hex 32
ADMIN_API_SECRET=REEMPLAZAR_CON_SECRET_SEGURO

# ── Client UI ────────────────────────────────────────────────
# Genera con: openssl rand -hex 32
CLIENT_UI_SECRET=REEMPLAZAR_CON_SECRET_SEGURO

# ── Modelos por agente (via OpenRouter) ──────────────────────
# CEO y CTO usan Opus — razonamiento complejo y decisiones críticas
MODEL_CEO=anthropic/claude-opus-4-7
MODEL_CTO=anthropic/claude-opus-4-7

# Research, Estilista, Onboarding Agent y QA usan Sonnet — balance costo/calidad
MODEL_RESEARCH=anthropic/claude-sonnet-4-6
MODEL_ESTILISTA=anthropic/claude-sonnet-4-6
MODEL_ONBOARDING_AGENT=anthropic/claude-sonnet-4-6
MODEL_QA=anthropic/claude-sonnet-4-6

# Coders usan Sonnet o Deepseek — velocidad, corre en paralelo
# Cambia a deepseek/deepseek-coder para reducir costos en proyectos grandes
MODEL_CODER=anthropic/claude-sonnet-4-6

# ── OpenClaw Gateway ─────────────────────────────────────────
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=4222
ADMIN_API_PORT=3000

# ── Base de datos ─────────────────────────────────────────────
# Genera con: openssl rand -hex 16
POSTGRES_PASSWORD=REEMPLAZAR_CON_PASSWORD_SEGURO
DATABASE_URL=postgresql://openclaw:${POSTGRES_PASSWORD}@postgres:5432/factory

# ── Memoria de agentes ────────────────────────────────────────
MEMORY_BACKEND=postgres

# ── ChromaDB ─────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000
